# Pantry Tracker — Environment Variables

# Supabase: project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI: free key at https://aistudio.google.com/app/apikey
# Powers receipt scanning + AI recipe suggestions. Without this, those
# features show a "configure key" prompt and the rest of the app still works.
# Users can also paste a personal key in Settings → AI (overrides this one,
# stored only in their browser localStorage).
VITE_GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to gemini-2.0-flash.
# VITE_GEMINI_MODEL=gemini-2.0-flash
